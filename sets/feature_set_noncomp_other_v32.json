[
  {
    "regex": "^pcm_zcr$",
    "normalize": true,
    "used_aggregates": [
      "median",
      "kurtosis",
      "max",
      "mean",
      "energy",
      "std"
    ],
    "target": "valence"
  },
  {
    "regex": "^pcm_zcr_sma$",
    "normalize": true,
    "used_aggregates": [
      "median",
      "kurtosis",
      "skewness",
      "energy",
      "slope",
      "std"
    ],
    "target": "valence"
  },
  {
    "regex": "^oenv$",
    "normalize": true,
    "used_aggregates": [
      "median",
      "mean",
      "slope",
      "energy",
      "min"
    ],
    "target": "valence"
  },
  {
    "regex": "^mean_mag$",
    "normalize": true,
    "used_aggregates": [
      "std",
      "energy",
      "median",
      "kurtosis",
      "max",
      "mean"
    ],
    "target": "valence"
  }
]